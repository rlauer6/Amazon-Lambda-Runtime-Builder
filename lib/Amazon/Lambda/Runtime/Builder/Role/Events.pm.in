package Amazon::Lambda::Runtime::Builder::Role::Events;

use strict;
use warnings;

use CLI::Simple::Constants qw(:booleans);
use Data::Dumper;
use English qw(-no_match_vars);
use JSON;

use Role::Tiny;

########################################################################
sub cmd_event_bridge_describe_rule {
########################################################################
  my ($self) = @_;

  my ($rule_name) = $self->get_args;

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $rsp = eval { $events->DescribeRule( { Name => $rule_name } ); };

  return $self->_check_response($rsp);
}

########################################################################
sub cmd_event_bridge_put_rule_expression {
########################################################################
  my ($self) = @_;

  my ( $rule_name, $expression, $state ) = $self->get_args;

  my $rsp = $self->_event_bridge_put_rule(
    expression => $expression,
    state      => $state,
    rule_name  => $rule_name
  );

  return $self->_check_response($rsp);
}

########################################################################
sub cmd_event_bridge_put_lambda_target {
########################################################################
  my ($self) = @_;

  my ( $function_name, $rule_name, $id ) = $self->get_args;
  $id //= 'lambda-handler';

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $lambda_function = $self->_lambda_get_function($function_name);
  my $function_arn    = $lambda_function->{Configuration}{FunctionArn};

  my $rsp = $events->PutTargets(
    { Rule    => $rule_name,
      Targets => [
        { Id  => $id,
          Arn => $function_arn
        }
      ]
    }
  );

  return $self->_check_response($rsp);
}

########################################################################
sub cmd_event_bridge_put_rule_pattern {
########################################################################
  my ($self) = @_;

  my ( $rule_name, $pattern, $state ) = $self->get_args;

  my $rsp = $self->_event_bridge_put_rule(
    pattern   => $pattern,
    state     => $state,
    rule_name => $rule_name
  );

  return $self->_check_response($rsp);
}

########################################################################
sub _event_bridge_put_rule {
########################################################################
  my ( $self, %args ) = @_;

  my ( $rule_name, $expression, $state, $pattern ) = @args{qw(rule_name expression state pattern)};

  $state //= 'ENABLED';
  $state = uc $state;

  die "ERROR: expression or pattern must be set\n"
    if !$expression && !$pattern;

  die "ERROR: set only one of expression or pattern\n"
    if $expression && $pattern;

  require Amazon::API::EventBridge;

  my $events = Amazon::API::EventBridge->new;

  my $rsp = $events->PutRule(
    { Name  => $rule_name,
      State => $state,
      $pattern    ? ( Pattern            => $pattern )    : (),
      $expression ? ( ScheduleExpression => $expression ) : (),
    }
  );

  return $self->_check_response($rsp);
}

########################################################################
sub cmd_event_bridge_disable_rule {
########################################################################
  my ($self) = @_;

  my ($rule_name) = $self->get_args;

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $rsp = $events->DisableRule( { Name => $rule_name } );

  if ( !$rsp && $EVAL_ERROR ) {
    print {*STDERR} $EVAL_ERROR;
    return $FAILURE;
  }

  return $self->cmd_event_bridge_describe_rule;
}

########################################################################
sub cmd_event_bridge_enable_rule {
########################################################################
  my ($self) = @_;

  my ($rule_name) = $self->get_args;

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $rsp = $events->EnableRule( { Name => $rule_name } );

  if ( !$rsp && $EVAL_ERROR ) {
    print {*STDERR} $EVAL_ERROR;
    return $FAILURE;
  }

  return $self->cmd_event_bridge_describe_rule;
}

########################################################################
sub cmd_event_bridge_remove_targets {
########################################################################
  my ($self) = @_;

  my ( $rule_name, @ids ) = $self->get_args;

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $rsp = $events->RemoveTargets( { Name => $rule_name, Ids => [@ids] } );

  return $self->_check_response($rsp);
}

########################################################################
sub cmd_event_bridge_delete_rule {
########################################################################
  my ($self) = @_;

  my ($rule_name) = $self->get_args;

  require Amazon::API::EventBridge;
  my $events = Amazon::API::EventBridge->new;

  my $rsp = $events->DeleteRule( { Name => $rule_name } );

  return $self->_check_response($rsp);
}

1;
